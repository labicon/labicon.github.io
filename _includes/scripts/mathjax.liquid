{% if site.enable_math %}
  <!-- MathJax -->
  <script type="text/javascript">
    window.MathJax = {
      tex: {
        tags: 'ams',
      },
    };
  </script>
  <script
    defer
    type="text/javascript"
    id="MathJax-script"
    src="{{ '/assets/js/mathjax/tex-mml-chtml.js' | relative_url }}"
  ></script>
{% endif %}
